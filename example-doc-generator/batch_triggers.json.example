{
  "triggers": [
    { "name": "graphql",        "package": "ballerina/graphql",
      "instructions": "GraphQL uses a resource-function model — there is no '+ Add Handler' side panel; instead use '+ Create Operations' to add a Query field, then 'Create New Type' for the return type. For screenshot 04, capture the 'Add Operations' / Query side panel, alt text 'GraphQL operations side panel — equivalent of Add Handler for message-based triggers'. For screenshot 05, capture the 'Create New Type' modal with a PascalCase name and 2+ fields, alt text 'GraphQL Create New Type modal — equivalent of Define Value for message-based triggers'." },
    { "name": "tcp",            "package": "ballerina/tcp",
      "instructions": "TCP auto-registers onConnect/onBytes/onError (no '+ Add Handler' side panel) and uses the library-defined TcpEchoService type (no Define Value modal). For screenshot 04 (_04_add_handler_panel), capture the Service view with the auto-generated Event Handlers list and prefix alt text with 'Auto-registered TCP event handlers (no Add Handler side panel for this trigger)'. For screenshot 05 (_05_message_define_value), capture the auto-generated TcpEchoService type/schema view (or the onConnect flow canvas if the type is not viewable) with alt text 'TcpEchoService library-defined type (no Define Value modal — payload type is provided by ballerina/tcp)'." },
    { "name": "rabbitmq",       "package": "ballerinax/rabbitmq" },
    { "name": "mqtt",           "package": "ballerina/mqtt",
      "instructions": "MQTT has '+ Add Handler' but uses the library-defined mqtt:Message payload type (no Define Value modal). Screenshot 04 (_04_add_handler_panel) is the literal Add Handler side panel — no override. For screenshot 05 (_05_message_define_value), capture the onMessage handler's initial flow canvas BEFORE the log edit, with alt text 'onMessage handler initial flow before log step (no Define Value modal — payload type mqtt:Message is library-defined)'." },
    { "name": "asb",            "package": "ballerinax/asb",
      "instructions": "ASB has '+ Add Handler' but uses the library-defined asb:Message payload type (no Define Value modal). The Entity Config field is a record type — use Expression mode to bind it as { queueName: queueName }, NOT the Record Configuration modal. For screenshot 05 (_05_message_define_value), capture the onMessage handler's initial flow canvas BEFORE the log edit, with alt text 'onMessage handler initial flow before log step (no Define Value modal — payload type asb:Message is library-defined)'." },
    { "name": "salesforce",     "package": "ballerinax/salesforce",
      "instructions": "The Salesforce service pre-registers all handlers (onCreate, onUpdate, onDelete, onRestore) — no '+ Add Handler' side panel and no Define Value modal. The auth field is a record type — use Expression mode (not the Record Configuration modal) to bind the auth sub-fields as { username: sfUsername, password: sfPassword }. For screenshot 04 (_04_add_handler_panel), capture the Service view with the auto-registered Event Handlers list, alt text 'Auto-registered Salesforce event handlers (no Add Handler side panel for this trigger)'. For screenshot 05 (_05_message_define_value), capture the onCreate handler's initial flow canvas BEFORE the log edit, alt text 'onCreate handler initial flow before log step (no Define Value modal — payload type salesforce:EventData is library-defined)'." },
    { "name": "trigger.twilio", "package": "ballerinax/trigger.twilio",
      "instructions": "Twilio's SmsStatusService pre-registers handlers (onAccepted, onSent, onReceived, etc.) — no '+ Add Handler' side panel and no Define Value modal. The primary handler is onReceived (NOT onSmsReceived). The Event Channel field is a dropdown — select SmsStatusService directly. For screenshot 04 (_04_add_handler_panel), capture the Service view with the pre-registered handlers list, alt text 'Auto-registered Twilio SMS event handlers (no Add Handler side panel for this trigger)'. For screenshot 05 (_05_message_define_value), capture the onReceived initial flow canvas, alt text 'onReceived handler initial flow before log step (no Define Value modal — payload type twilio:SmsStatusChangeEventWrapper is library-defined)'." },
    { "name": "trigger.github", "package": "ballerinax/trigger.github",
      "instructions": "The Event Channel field is a dropdown — select IssuesService directly, do not create a Configurable for it. The primary handler is onOpened." },
    { "name": "postgresql",     "package": "ballerinax/postgresql",
      "instructions": "CDC for PostgreSQL uses '+ Add Handler' and Define Value (Database Entry). The primary handler is onCreate for row-insert events; handler parameter is afterEntry." },
    { "name": "ftp",            "package": "ballerina/ftp",
      "instructions": "FTP auto-registers onFileChange (no '+ Add Handler' side panel) and uses the library-defined ftp:WatchEvent payload type (no Define Value modal). For screenshot 04, capture the Service view with the pre-registered handler, alt text 'Auto-registered FTP event handler (no Add Handler side panel for this trigger)'. For screenshot 05, capture the initial flow canvas, alt text 'onFileChange initial flow before log step (no Define Value modal — payload type ftp:WatchEvent is library-defined)'." },
    { "name": "file",           "package": "ballerina/file",
      "instructions": "Local Files trigger auto-registers onCreate/onModify/onDelete (no '+ Add Handler' side panel) and uses the library-defined file:FileEvent payload type (no Define Value modal). For screenshot 04, capture the Service view with the pre-registered handlers list, alt text 'Auto-registered file event handlers (no Add Handler side panel for this trigger)'. For screenshot 05, capture the onCreate initial flow canvas, alt text 'onCreate handler initial flow before log step (no Define Value modal — payload type file:FileEvent is library-defined)'." }
  ],
  "docsBranch":    "docs/trigger-docs",
  "samplesBranch": "samples/trigger-samples"
}
